POST http://localhost:8080/devices
Content-Type: application/json

{
  "name": "Light 3",
  "type": "LIGHT",
  "room": "Salon",
  "pin": 9
}

################


POST http://localhost:8080/rooms
Content-Type: application/json

{
  "name": "Salon",
  "devices": [
    { "type": "LIGHT", "pin": 7 },
    { "type": "DOOR", "pin": 8 }
  ]
}

